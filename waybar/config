{
  "layer": "bot",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 4,
  "position": "top",
  "margin-right": 12,
  "margin-left": 12,
  "modules-left": [
    "sway/workspaces",
    "wlr/taskbar"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "network",
    "battery",
    "pulseaudio",
    "tray"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "all-outputs": true,
    "tooltip-format": "{title}",
    "on-click": "activate"
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },
  "clock": {
    "format": "󰅐  {:%H:%M}",
    "tooltip": false
  },
  "network": {
    "format-wifi": "  {bandwidthDownBits}",
    "format-ethernet": "  {bandwidthDownBits}",
    "format-disconnected": "󰤮  No Network",
    "interval": 5,
    "tooltip": false
  },
  "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon} {volume}%",
      "format-muted": "  Muted",
      "format-icons": {
          "default": ["", "", " "]
      },
      "on-click": "yad --scale --title='VolumeSlider' --no-buttons --width=200 --height=20 --undecorated --mouse --on-top --close-on-unfocus --print-partial --value=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}') | xargs -I {} wpctl set-volume @DEFAULT_AUDIO_SINK@ {}%"
  },
  "cpu": {
    "format": " {usage}%",
    "interval": 3,
    "tooltip": false
  },
  
  "memory": {
      "interval": 5,
      "format": "󰘚 {percentage}%",
      "states": {
          "warning": 70,
          "critical": 90
      },
      "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄{capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "󱈑 {capacity}%",
    "format-icons": [
      "󱊡",
      "󱊢",
      "󱊣"
    ]
  }
}
